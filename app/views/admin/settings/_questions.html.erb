<%= form_with url: admin_question_scores_path, method: :patch do |form| %>
  <% questions.each_with_index do |question, index| %>
    <div class="field">
      <strong>Question:</strong> <%= question.question %><br>
      <strong>Answer:</strong> <%= question.answer %>
    </div>

    <div class="columns">
      <% question.question_scores.each do |question_score| %>
        <div class="column">
          <div class="field">
            <%= form.label "question_scores[][score]", "#{question_score.age_range.min} - #{question_score.age_range.max}", class: "has-text-weight-bold" %>
            <div class="control">
              <%= form.number_field "question_scores[][score]", value: question_score.score, class: "input" %>
            </div>
          </div>
        </div>

        <%= form.hidden_field "question_scores[][id]", value: question_score.id %>
      <% end %>
    </div>
  <% end %>

  <div class="field">
    <div class="control">
      <%= form.submit "Save Question Scores", class: "button is-primary" %>
    </div>
  </div>
<% end %>